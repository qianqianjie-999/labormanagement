# =====================================================
# 劳动用工管理系统 - 服务器环境配置示例
# =====================================================
# 说明：在 CentOS 9 Stream 服务器上使用时
#       1. 复制此文件为 .env
#       2. 根据实际环境修改配置值
# =====================================================

# -----------------------------------------------------
# 运行环境配置
# -----------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=False

# -----------------------------------------------------
# 安全密钥 (必须修改！)
# -----------------------------------------------------
# 生成方法：python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# -----------------------------------------------------
# 数据库配置 (CentOS 9 Stream - IPv6)
# -----------------------------------------------------
# 如果 MySQL 监听 IPv6 地址
DATABASE_URL=mysql+pymysql://labor_app_user:labor_app_password@[::1]:3306/labor_application_db

# 如果 MySQL 监听 IPv4 地址 (取消下面这行的注释)
# DATABASE_URL=mysql+pymysql://labor_app_user:labor_app_password@127.0.0.1:3306/labor_application_db

# -----------------------------------------------------
# 日志配置
# -----------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------
# CORS 配置 (根据实际前端地址修改)
# -----------------------------------------------------
# 如果前后端分离，填写前端地址
# 如果使用 Apache 统一代理，可设置为当前域名
CORS_ORIGINS=*

# -----------------------------------------------------
# 生产环境可选配置
# -----------------------------------------------------
# 服务器端口（Apache/Gunicorn 监听）
# FLASK_RUN_PORT=5000

# 服务器主机
# FLASK_RUN_HOST=0.0.0.0
