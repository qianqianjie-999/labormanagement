# =====================================================
# 劳动用工管理系统 - 环境配置文件
# =====================================================
# 说明：复制此文件为 .env 并填入实际配置值
# 注意：.env 文件包含敏感信息，不应提交到版本控制系统
# =====================================================

# -----------------------------------------------------
# 运行环境配置
# -----------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

# -----------------------------------------------------
# 安全配置
# -----------------------------------------------------
# 生产环境请使用：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# -----------------------------------------------------
# 数据库配置
# -----------------------------------------------------
# MySQL/MariaDB 连接配置
# 格式：mysql+pymysql://用户名：密码@主机：端口/数据库名
DATABASE_URL=mysql+pymysql://labor_app_user:labor_app_password@127.0.0.1:3306/labor_application_db

# 数据库连接池配置
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_ECHO=False

# -----------------------------------------------------
# 日志配置
# -----------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - [%(filename)s:%(lineno)d] - %(message)s
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# -----------------------------------------------------
# 文件上传配置
# -----------------------------------------------------
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=xlsx,xls

# -----------------------------------------------------
# 导出配置
# -----------------------------------------------------
PDF_EXPORT_FOLDER=exports
EXPORT_BATCH_SIZE=100

# -----------------------------------------------------
# 跨域配置 (CORS) - 前后端分离必需
# -----------------------------------------------------
# 前端开发服务器地址
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
CORS_SUPPORTS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# -----------------------------------------------------
# JWT 配置 (用于前后端分离的身份验证)
# -----------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# -----------------------------------------------------
# 缓存配置
# -----------------------------------------------------
CACHE_TYPE=filesystem
CACHE_DIR=cache

# -----------------------------------------------------
# 生产环境专用配置
# -----------------------------------------------------
# 生产环境数据库（如与开发环境不同）
# PROD_DATABASE_URL=mysql+pymysql://user:pass@prod-host:3306/db_name

# 服务器域名
# SERVER_NAME=labormanagement.example.com

# HTTPS 配置
# SESSION_COOKIE_SECURE=true
# REMEMBER_COOKIE_SECURE=true
