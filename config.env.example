# 应用程序配置文件示例
# 复制此文件为 config.env 并填入实际配置值
# 注意：config.env 文件不应提交到版本控制系统

# 安全密钥 - 生产环境请使用随机生成的长字符串
# 可使用以下命令生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# 数据库配置
DATABASE_URL=mysql+pymysql://labor_app_user:labor_app_password@127.0.0.1:3306/labor_application_db

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 运行环境 (development, production, testing)
FLASK_ENV=development

# 服务器端口（仅开发环境）
FLASK_RUN_PORT=5000

# 服务器主机 (0.0.0.0 表示监听所有接口)
FLASK_RUN_HOST=127.0.0.1
